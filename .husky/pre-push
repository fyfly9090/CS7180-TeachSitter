#!/bin/sh

# 1. Auto-fix Prettier formatting
echo "▶ pre-push: formatting with Prettier..."
npx prettier --write . 2>/dev/null
# Stage any formatting fixes so they're included in the push
git add -u

# 2. ESLint (errors only — warnings are pre-existing and non-blocking)
echo "▶ pre-push: running ESLint..."
npx eslint . || { echo "✗ ESLint errors — push aborted"; exit 1; }

# 3. Unit tests
echo "▶ pre-push: running tests..."
npm run test || { echo "✗ Tests failed — push aborted"; exit 1; }

echo "✓ All checks passed — pushing."
