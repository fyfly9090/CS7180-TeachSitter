#!/bin/sh

# 1. Verify formatting (don't auto-fix — committed code must already be formatted)
echo "▶ pre-push: checking formatting..."
npx prettier --check . || { echo "✗ Prettier check failed — run: npx prettier --write . && git add -u && git commit --amend --no-edit"; exit 1; }

# 2. ESLint (errors only — warnings are non-blocking)
echo "▶ pre-push: running ESLint..."
npx eslint . || { echo "✗ ESLint errors — push aborted"; exit 1; }

# 3. Unit tests
echo "▶ pre-push: running tests..."
npm run test || { echo "✗ Tests failed — push aborted"; exit 1; }

echo "✓ All checks passed — pushing."
